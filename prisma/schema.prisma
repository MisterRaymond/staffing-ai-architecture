// ============================================================
// StaffingAI — Prisma Schema
// Multi-Tenant SaaS de Staffing IT avec IA
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Plan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CHURNED
}

// ─────────────────────────────────────────────
// RBAC — Rôles & Permissions dynamiques
// ─────────────────────────────────────────────
// Les rôles ne sont PAS figés. Chaque Organisation
// crée ses propres rôles et y affecte des permissions.
// Des rôles par défaut sont créés à l'onboarding
// mais l'admin peut les modifier librement.
// ─────────────────────────────────────────────

model Permission {
  id          String @id @default(cuid())
  code        String @unique                     // Ex: "candidates:create", "finance:view"
  name        String                              // Ex: "Créer un candidat"
  description String?                             // Description longue
  module      String                              // Module : candidates, missions, finance, pipeline, teams, admin, integrations
  action      String                              // Action : create, read, update, delete, export, manage, match

  // Relations
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model Role {
  id            String   @id @default(cuid())
  name          String                            // Ex: "Directeur Delivery", "Chargé de Recrutement"
  description   String?
  color         String?                           // Couleur UI pour badge
  isSystem      Boolean  @default(false)          // true = rôle créé à l'onboarding, non supprimable
  isDefault     Boolean  @default(false)          // Rôle assigné par défaut aux nouveaux users
  hierarchy     Int      @default(0)              // Niveau hiérarchique (0 = le plus bas, 100 = admin)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users           User[]
  rolePermissions RolePermission[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model RolePermission {
  id String @id @default(cuid())

  roleId String
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Scope : restreindre la permission à un périmètre de données
  scope String @default("all")  // "own" = ses données, "team" = son pôle, "all" = tout le tenant

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

enum PoolStatus {
  IN_POOL           // Disponible dans le vivier pour futures missions
  ACTIVE_PROCESS    // En cours de process sur une mission
  ON_MISSION        // Actuellement en mission
  BLACKLISTED       // Ne plus contacter
  DO_NOT_CONTACT    // Demande du candidat
}

enum CandidateSource {
  MANUAL_IMPORT       // Upload direct dans le SaaS
  SMART_RECRUITERS    // Import SmartRecruiters
  LINKEDIN_RECRUITER  // Import LinkedIn Recruiter
  INDEED              // Import Indeed
  MONSTER             // Import Monster
  WELCOME_TO_JUNGLE   // Import WTTJ
  APEC                // Import APEC
  JOBBOARD_OTHER      // Autre jobboard
  REFERRAL            // Cooptation
  INBOUND             // Candidature spontanée
  CAREER_SITE         // Site carrière de l'ESN
}

enum MissionStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  FILLED
  CLOSED
  CANCELLED
}

enum PipelineStage {
  NEW
  PRESELECTED
  QUALIFYING            // Étape flexible — le Responsable active les activités qu'il veut
  PROPOSED_TO_CLIENT
  CLIENT_INTERVIEW
  VALIDATED
  ON_MISSION
  REJECTED
  CANCELLED
}

enum ActivityType {
  TECHNICAL_EVALUATION    // Évaluation technique par un Expert
  INTERNAL_INTERVIEW      // Entretien interne (RH, motivation, soft skills)
  TECHNICAL_TEST          // Test technique en ligne (ex: CodinGame, HackerRank)
  REFERENCE_CHECK         // Vérification des références
  SALARY_NEGOTIATION      // Négociation salariale / TJM
  DOCUMENT_COLLECTION     // Collecte de documents (diplômes, certifs)
  CLIENT_PRESCREEN        // Pré-qualification par le client (avant entretien formel)
  OTHER                   // Activité libre
}

enum ActivityStatus {
  PENDING       // Planifiée, pas encore commencée
  IN_PROGRESS   // En cours
  COMPLETED     // Terminée
  CANCELLED     // Annulée
  OVERDUE       // En retard (deadline dépassée)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE
  CLOUD
  DEVOPS
  METHODOLOGY
  SOFT_SKILL
  OTHER
}

enum Recommendation {
  STRONG_MATCH
  GOOD_MATCH
  PARTIAL_MATCH
  WEAK_MATCH
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  PORTAGE
}

enum RemotePolicy {
  ON_SITE
  HYBRID
  FULL_REMOTE
}

enum Availability {
  IMMEDIATE
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS_PLUS
  NOT_AVAILABLE
}

enum Seniority {
  JUNIOR
  MID
  SENIOR
  LEAD
  ARCHITECT
}

enum PlacementStatus {
  ACTIVE
  COMPLETED
  EARLY_TERMINATION
  RENEWED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  EXPORT
  IMPERSONATE
}

enum ParsingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// ORGANIZATION (Tenant)
// ─────────────────────────────────────────────

model Organization {
  id                     String    @id @default(cuid())
  name                   String
  slug                   String    @unique
  logo                   String?
  plan                   Plan      @default(TRIAL)
  status                 OrgStatus @default(ACTIVE)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  settings               Json      @default("{}")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  users                User[]
  roles                Role[]
  candidates           Candidate[]
  clients        Client[]
  missions       Mission[]
  placements     Placement[]
  applications   Application[]
  staffingTeams        StaffingTeam[]
  sourcingIntegrations SourcingIntegration[]
  notifications        Notification[]
  auditLogs            AuditLog[]

  @@map("organizations")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  clerkId           String    @unique
  email             String    @unique
  firstName         String
  lastName          String
  avatar            String?
  isSuperAdmin      Boolean   @default(false)  // Provider du SaaS uniquement
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Rôle dynamique (RBAC)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Staffing Teams
  ledTeams             StaffingTeam[]   @relation("TeamLead")
  staffingTeamMembers  StaffingTeamMember[]

  createdCandidates Candidate[] @relation("CreatedBy")
  createdMissions   Mission[]   @relation("CreatedBy")
  assignedApplications Application[] @relation("AssignedTo")
  assignedActivities   ApplicationActivity[] @relation("ActivityAssignee")
  createdActivities    ApplicationActivity[] @relation("ActivityCreator")
  evaluations          TechnicalEvaluation[] @relation("Evaluator")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationSender")
  notificationPreferences NotificationPreference[]
  auditLogs         AuditLog[]

  @@index([organizationId])
  @@index([roleId])
  @@map("users")
}

// ─────────────────────────────────────────────
// STAFFING TEAM (Pôle / Équipe de recrutement)
// ─────────────────────────────────────────────

model StaffingTeam {
  id            String   @id @default(cuid())
  name          String                           // Ex: "Pôle Java", "Équipe Data BNP", "Testing Société Générale"
  description   String?  @db.Text
  specialization String?                          // Ex: "Java/JEE", "Data Engineering", "QA/Testing"
  color         String?                           // Couleur UI pour identifier le pôle
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Manager lead du pôle
  leadId String?
  lead   User?   @relation("TeamLead", fields: [leadId], references: [id])

  // Client associé (optionnel — un pôle peut être par client ou par techno)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // Membres du pôle
  members    StaffingTeamMember[]
  // Candidats du vivier associés à ce pôle
  candidates CandidatePool[]
  // Missions gérées par ce pôle
  missions   Mission[]

  @@index([organizationId])
  @@index([clientId])
  @@map("staffing_teams")
}

model StaffingTeamMember {
  id        String   @id @default(cuid())
  role      String   @default("RECRUITER") // DELIVERY_MANAGER, RECRUITMENT_LEAD, RECRUITER, SOURCING_OFFICER
  joinedAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  staffingTeamId String
  staffingTeam   StaffingTeam @relation(fields: [staffingTeamId], references: [id], onDelete: Cascade)

  @@unique([userId, staffingTeamId])
  @@map("staffing_team_members")
}

// ─────────────────────────────────────────────
// CANDIDATE
// ─────────────────────────────────────────────

model Candidate {
  id                   String        @id @default(cuid())
  firstName            String
  lastName             String
  email                String
  phone                String?
  location             String?
  cvFileUrl            String?
  cvFileName           String?
  cvParsedData         Json?
  availability         Availability  @default(NOT_AVAILABLE)
  availableFrom        DateTime?
  desiredSalaryAnnual  Decimal?      @db.Decimal(10, 2)
  desiredTJM           Decimal?      @db.Decimal(10, 2)
  preferredContract    ContractType?
  preferredRemote      RemotePolicy?
  seniorityEstimate    Seniority?
  linkedinUrl          String?
  source               CandidateSource @default(MANUAL_IMPORT)
  sourceDetail         String?                          // Détail libre (ex: "LinkedIn post du 12/03")
  sourcedById          String?                          // Chargé de recrutement qui a sourcé
  importedFromTool     String?                          // ID externe dans l'outil source
  notes                String?       @db.Text
  // ── Vivier / Talent Pool ──
  poolStatus           PoolStatus    @default(IN_POOL)
  poolNotes            String?       @db.Text      // Notes pour le vivier (pourquoi garder ce profil)
  lastContactedAt      DateTime?                    // Dernier contact avec le candidat
  poolScore            Int?                          // Score de "chaleur" 1-5 (5 = très chaud)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("CreatedBy", fields: [createdById], references: [id])

  skills        Skill[]
  experiences   Experience[]
  applications  Application[]
  matchScores   MatchScore[]
  placements    Placement[]
  tags          CandidateTag[]         // Tags de catégorisation
  poolHistory   CandidatePoolHistory[] // Historique dans le vivier
  pools         CandidatePool[]        // Appartenance aux pôles

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([organizationId, availability])
  @@index([organizationId, poolStatus])
  @@map("candidates")
}

// ─────────────────────────────────────────────
// CANDIDATE TAG (Étiquettes pour le vivier)
// ─────────────────────────────────────────────

model CandidateTag {
  id    String @id @default(cuid())
  name  String // Ex: "Java Senior", "Disponible Q2", "Ex-BNP", "Profil rare"
  color String? // Couleur UI

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  organizationId String

  @@index([candidateId])
  @@index([organizationId, name])
  @@map("candidate_tags")
}

// ─────────────────────────────────────────────
// CANDIDATE POOL (Appartenance à un Staffing Team / Pôle)
// ─────────────────────────────────────────────

model CandidatePool {
  id       String   @id @default(cuid())
  addedAt  DateTime @default(now())
  addedBy  String?                      // userId qui a ajouté le candidat au pôle
  notes    String?  @db.Text

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  staffingTeamId String
  staffingTeam   StaffingTeam @relation(fields: [staffingTeamId], references: [id], onDelete: Cascade)

  @@unique([candidateId, staffingTeamId])
  @@map("candidate_pools")
}

// ─────────────────────────────────────────────
// CANDIDATE POOL HISTORY (Historique du vivier)
// ─────────────────────────────────────────────

model CandidatePoolHistory {
  id              String   @id @default(cuid())
  action          String                  // "ADDED_TO_POOL", "REJECTED_FROM_MISSION", "REACTIVATED", "CONTACTED", "BLACKLISTED"
  fromMissionId   String?                 // Mission d'où vient le candidat (si rejeté)
  fromMissionTitle String?                // Titre de la mission (pour historique lisible)
  rejectionReason String?                 // Raison du rejet (si applicable)
  previousPoolStatus PoolStatus?
  newPoolStatus   PoolStatus?
  notes           String?  @db.Text
  performedById   String?                 // userId qui a fait l'action
  createdAt       DateTime @default(now())

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt(sort: Desc)])
  @@map("candidate_pool_history")
}

// ─────────────────────────────────────────────
// SKILL
// ─────────────────────────────────────────────

model Skill {
  id               String        @id @default(cuid())
  name             String
  normalizedName   String
  category         SkillCategory @default(OTHER)
  level            SkillLevel    @default(INTERMEDIATE)
  yearsOfExperience Int?
  isVerified       Boolean       @default(false)

  // Relations
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([normalizedName])
  @@map("skills")
}

// ─────────────────────────────────────────────
// EXPERIENCE
// ─────────────────────────────────────────────

model Experience {
  id           String    @id @default(cuid())
  companyName  String
  jobTitle     String
  description  String?   @db.Text
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  technologies String[]

  // Relations
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("experiences")
}

// ─────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  companyName  String
  sector       String?
  contactName  String
  contactEmail String
  contactPhone String?
  address      String?
  notes        String?  @db.Text
  defaultTJM   Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  missions       Mission[]
  placements     Placement[]
  staffingTeams  StaffingTeam[]

  @@index([organizationId])
  @@map("clients")
}

// ─────────────────────────────────────────────
// MISSION
// ─────────────────────────────────────────────

model Mission {
  id                     String        @id @default(cuid())
  title                  String
  description            String        @db.Text
  tjmClient              Decimal?      @db.Decimal(10, 2)
  tjmBudgetMax           Decimal?      @db.Decimal(10, 2)
  status                 MissionStatus @default(DRAFT)
  startDate              DateTime?
  estimatedEndDate       DateTime?
  estimatedDurationMonths Int?
  location               String?
  remotePolicy           RemotePolicy  @default(ON_SITE)
  requiredSeniority      Seniority?
  positionsCount         Int           @default(1)
  positionsFilled        Int           @default(0)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdById String?
  createdBy   User?   @relation("CreatedBy", fields: [createdById], references: [id])

  // Pôle / Équipe qui gère cette mission (optionnel)
  staffingTeamId String?
  staffingTeam   StaffingTeam? @relation(fields: [staffingTeamId], references: [id])

  jobDescription JobDescription?
  requiredSkills RequiredSkill[]
  matchScores    MatchScore[]
  applications   Application[]
  placements     Placement[]

  @@index([organizationId, status])
  @@index([clientId])
  @@map("missions")
}

// ─────────────────────────────────────────────
// JOB DESCRIPTION (Fiche de Poste / Appel d'Offre)
// ─────────────────────────────────────────────

model JobDescription {
  id               String   @id @default(cuid())
  fileUrl          String                           // URL du fichier original (PDF/DOCX)
  fileName         String                           // Nom original du fichier
  fileType         String                           // "application/pdf", "application/docx"
  rawText          String?  @db.Text                // Texte brut extrait du document
  parsedData       Json?                            // Données structurées extraites par l'IA
  // Champs extraits par l'IA (dénormalisés pour requêtes rapides)
  extractedTitle         String?                    // Titre du poste extrait
  extractedDescription   String?  @db.Text          // Description extraite
  extractedSkills        Json?                      // [{name, level, mandatory}] extraits
  extractedSeniority     Seniority?                 // Séniorité extraite
  extractedExperience    Int?                       // Années d'expérience requises
  extractedLocation      String?                    // Localisation extraite
  extractedRemotePolicy  RemotePolicy?              // Politique remote extraite
  extractedBudget        Decimal? @db.Decimal(10,2) // TJM ou budget extrait
  extractedStartDate     DateTime?                  // Date de démarrage extraite
  extractedDuration      String?                    // Durée extraite (ex: "6 mois")
  extractedCertifications Json?                     // Certifications requises
  extractedLanguages     Json?                      // Langues requises
  // Statut de parsing
  parsingStatus    ParsingStatus @default(PENDING)
  parsingError     String?                          // Message d'erreur si échec
  parsedAt         DateTime?                        // Date du dernier parsing
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  missionId String   @unique                        // 1 fiche de poste par mission
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("job_descriptions")
}

// ─────────────────────────────────────────────
// REQUIRED SKILL (pour une mission)
// ─────────────────────────────────────────────

model RequiredSkill {
  id             String     @id @default(cuid())
  skillName      String
  normalizedName String
  minimumLevel   SkillLevel @default(INTERMEDIATE)
  isMandatory    Boolean    @default(true)
  weight         Int        @default(5) // 1-10

  // Relations
  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@map("required_skills")
}

// ─────────────────────────────────────────────
// MATCH SCORE
// ─────────────────────────────────────────────

model MatchScore {
  id                String         @id @default(cuid())
  globalScore       Int
  technicalScore    Int
  seniorityScore    Int
  locationScore     Int
  availabilityScore Int
  skillMatchDetail  Json
  strengths         Json           // String[]
  gaps              Json           // String[]
  recommendation    Recommendation
  aiExplanation     String?        @db.Text
  computedAt        DateTime       @default(now())

  // Relations
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([candidateId, missionId])
  @@index([missionId, globalScore(sort: Desc)])
  @@map("match_scores")
}

// ─────────────────────────────────────────────
// APPLICATION (Candidature dans le pipeline)
// ─────────────────────────────────────────────

model Application {
  id              String        @id @default(cuid())
  stage           PipelineStage @default(NEW)
  notes           String?       @db.Text
  rejectionReason String?
  rejectionCategory String?     // "SKILL_GAP", "SENIORITY", "BUDGET", "TIMING", "CLIENT_REFUSAL", "CANDIDATE_WITHDRAWAL", "OTHER"
  reinjectedToPool Boolean     @default(false) // Candidat réinjecté dans le vivier après rejet
  interviewDate   DateTime?
  appliedAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  missionId String
  mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  evaluations  TechnicalEvaluation[]
  activities   ApplicationActivity[]

  @@unique([candidateId, missionId])
  @@index([organizationId, stage])
  @@index([missionId])
  @@map("applications")
}

// ─────────────────────────────────────────────
// APPLICATION ACTIVITY (Activités de qualification)
// ─────────────────────────────────────────────
// Les activités sont des étapes optionnelles que le
// Responsable Recrutement déclenche librement pendant
// la phase QUALIFYING. Pas d'ordre imposé.
// ─────────────────────────────────────────────

model ApplicationActivity {
  id              String         @id @default(cuid())
  type            ActivityType
  status          ActivityStatus @default(PENDING)
  title           String                             // Ex: "Entretien technique Java avec Ahmed"
  description     String?        @db.Text
  // Planification
  scheduledAt     DateTime?                          // Date prévue
  deadline        DateTime?                          // Date limite
  completedAt     DateTime?
  // Résultat
  outcome         String?                            // "PASS", "FAIL", "CONDITIONAL", ou texte libre
  outcomeNotes    String?        @db.Text            // Notes de résultat détaillées
  // Assignation
  assignedToId    String?                            // User responsable de cette activité
  assignedTo      User?          @relation("ActivityAssignee", fields: [assignedToId], references: [id])
  // Lien vers l'évaluation technique détaillée (si type = TECHNICAL_EVALUATION)
  evaluationId    String?        @unique
  evaluation      TechnicalEvaluation? @relation(fields: [evaluationId], references: [id])
  // Pièces jointes
  attachmentUrl   String?
  attachmentName  String?
  // Ordre d'affichage (optionnel, pour réordonner les activités)
  sortOrder       Int            @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  applicationId   String
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdById     String?
  createdBy       User?          @relation("ActivityCreator", fields: [createdById], references: [id])

  @@index([applicationId, status])
  @@map("application_activities")
}

// ─────────────────────────────────────────────
// TECHNICAL EVALUATION (Évaluation technique)
// ─────────────────────────────────────────────

model TechnicalEvaluation {
  id              String           @id @default(cuid())
  applicationId   String
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // L'expert technique qui évalue
  evaluatorId     String
  evaluator       User             @relation("Evaluator", fields: [evaluatorId], references: [id])

  // Verdict global
  verdict         EvaluationVerdict
  globalScore     Int                              // 0-100
  summary         String           @db.Text        // Synthèse écrite de l'évaluation
  recommendation  String?          @db.Text        // "Pousser au client car...", "Ne pas proposer car..."

  // Scores détaillés par compétence
  skillScores     Json                              // [{ skill, score: 0-5, level: "confirmé", notes: "..." }]

  // Entretien
  interviewDate   DateTime                          // Date de l'entretien technique
  durationMinutes Int?                              // Durée de l'entretien
  interviewType   String           @default("visio") // "visio", "phone", "on_site", "live_coding", "take_home"

  // Questions / Exercices posés (pour capitalisation)
  questionsAsked  Json?                             // [{ question, domain, candidateAnswer, score }]

  // Soft skills observés lors de l'entretien
  softSkillNotes  String?          @db.Text        // Communication, motivation, culture fit

  // Pièces jointes (ex: résultat d'un test technique)
  attachmentUrl   String?
  attachmentName  String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Reverse relation to activity
  activity        ApplicationActivity?

  @@index([applicationId])
  @@index([evaluatorId])
  @@map("technical_evaluations")
}

enum EvaluationVerdict {
  STRONG_YES     // Excellent, pousser au client immédiatement
  YES            // Bon niveau, correspond au besoin
  CONDITIONAL    // OK sous conditions (ex: formation sur un outil spécifique)
  NO             // Ne correspond pas techniquement
  STRONG_NO      // Niveau insuffisant, ne pas proposer
}

// ─────────────────────────────────────────────
// PLACEMENT
// ─────────────────────────────────────────────

model Placement {
  id            String          @id @default(cuid())
  startDate     DateTime
  endDate       DateTime?
  actualEndDate DateTime?
  contractType  ContractType
  status        PlacementStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  missionId String
  mission   Mission @relation(fields: [missionId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  financialRecords FinancialRecord[]

  @@index([organizationId, status])
  @@index([candidateId])
  @@map("placements")
}

// ─────────────────────────────────────────────
// FINANCIAL RECORD
// ─────────────────────────────────────────────

model FinancialRecord {
  id                   String   @id @default(cuid())
  month                String   // Format: "2025-03"
  tjmVente             Decimal  @db.Decimal(10, 2)
  tjmAchat             Decimal? @db.Decimal(10, 2) // Si freelance
  salaireBrutMensuel   Decimal? @db.Decimal(10, 2) // Si CDI
  chargesPatronalesPct Decimal  @default(0.45) @db.Decimal(5, 4)
  fraisGestionPct      Decimal  @default(0.05) @db.Decimal(5, 4)
  joursOuvres          Int
  joursTravailles      Int
  caMensuel            Decimal  @db.Decimal(12, 2)
  coutMensuel          Decimal  @db.Decimal(12, 2)
  margeBrute           Decimal  @db.Decimal(12, 2)
  margeNette           Decimal  @db.Decimal(12, 2)
  tauxMarge            Decimal  @db.Decimal(5, 2) // Pourcentage
  createdAt            DateTime @default(now())

  // Relations
  placementId String
  placement   Placement @relation(fields: [placementId], references: [id], onDelete: Cascade)

  @@unique([placementId, month])
  @@index([placementId])
  @@map("financial_records")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id            String             @id @default(cuid())
  type          String                              // Ex: "evaluation_assigned", "mission_ending_soon"
  channel       NotificationChannel                 // IN_APP, EMAIL, BOTH
  title         String                              // Titre court affiché
  message       String             @db.Text         // Corps du message
  isRead        Boolean            @default(false)
  readAt        DateTime?
  // Lien vers l'entité concernée
  entityType    String?                             // "application", "mission", "candidate", "placement"
  entityId      String?                             // ID de l'entité pour navigation directe
  actionUrl     String?                             // URL relative pour clic (ex: "/missions/xxx/matches")
  // Métadonnées
  metadata      Json?                               // Données additionnelles spécifiques au type
  expiresAt     DateTime?                           // Auto-suppression après cette date
  createdAt     DateTime           @default(now())

  // Destinataire
  recipientId   String
  recipient     User               @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  // Émetteur (null si système)
  senderId      String?
  sender        User?              @relation("NotificationSender", fields: [senderId], references: [id])

  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([organizationId, type])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  eventType   String                                // Ex: "evaluation_assigned", "mission_ending_soon"
  inApp       Boolean  @default(true)               // Recevoir en notification in-app
  email       Boolean  @default(true)               // Recevoir par email
  enabled     Boolean  @default(true)               // Activer/désactiver complètement

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
  @@map("notification_preferences")
}

model NotificationTemplate {
  id          String   @id @default(cuid())
  eventType   String   @unique                      // Ex: "evaluation_assigned"
  titleTemplate   String                             // "Évaluation assignée : {{candidateName}}"
  messageTemplate String @db.Text                    // "{{senderName}} vous a assigné l'évaluation de {{candidateName}} pour la mission {{missionTitle}}."
  emailSubject    String?                            // Sujet email (si différent du titre)
  emailTemplate   String? @db.Text                   // Template email HTML (si différent du message)
  defaultChannels NotificationChannel @default(BOTH)
  isActive    Boolean  @default(true)
  
  @@map("notification_templates")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BOTH
}

// ─────────────────────────────────────────────
// SOURCING INTEGRATION (Connexions outils externes)
// ─────────────────────────────────────────────

model SourcingIntegration {
  id              String          @id @default(cuid())
  provider        CandidateSource                   // SMART_RECRUITERS, LINKEDIN_RECRUITER, etc.
  name            String                             // Nom affiché (ex: "SmartRecruiters - Compte Prod")
  isActive        Boolean         @default(true)
  apiKey          String?                            // Clé API chiffrée
  apiUrl          String?                            // URL de l'API du provider
  webhookUrl      String?                            // URL du webhook pour réception de CVs
  webhookSecret   String?                            // Secret pour valider les webhooks
  settings        Json            @default("{}")     // Config spécifique au provider
  lastSyncAt      DateTime?                          // Dernier sync réussi
  syncFrequency   String?                            // "realtime", "hourly", "daily"
  candidatesImported Int          @default(0)        // Compteur total de CVs importés
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@map("sourcing_integrations")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  entityType     String
  entityId       String?
  previousData   Json?
  newData        Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
